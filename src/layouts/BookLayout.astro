---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { 
  title, 
  description = "コンピュータサイエンスを体系的に学ぶ教科書",
  currentPath = "" 
} = Astro.props;

// base url (for GitHub Pages deployment)
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;

// Curriculum navigation structure
const chapters = [
  {
    number: "1",
    title: "情報の表現",
    sections: [
      { id: "1-1", title: "電球1個から始める通信", path: "chapter1/section1" },
      { id: "1-2", title: "数の表現：2進数と16進数", path: "chapter1/section2" },
      { id: "1-3", title: "文字の表現：ASCIIからUnicodeへ", path: "chapter1/section3" },
      { id: "1-4", title: "メモリの中を覗く：バイトとエンディアン", path: "chapter1/section4" },
    ]
  },
  {
    number: "2",
    title: "論理回路からCPUへ",
    sections: [
      { id: "2-1", title: "スイッチとしてのトランジスタ", path: "chapter2/section1" },
      { id: "2-2", title: "基本論理回路と真理値表", path: "chapter2/section2" },
      { id: "2-3", title: "計算の実現：加算器", path: "chapter2/section3" },
      { id: "2-4", title: "クロックと同期：記憶の回路", path: "chapter2/section4" },
      { id: "2-5", title: "CPUの設計図", path: "chapter2/section5" },
    ]
  },
  {
    number: "3",
    title: "プログラムとメモリ",
    sections: [
      { id: "3-1", title: "ソースコードから機械語へ", path: "chapter3/section1" },
      { id: "3-2", title: "メモリ階層：レジスタからストレージまで", path: "chapter3/section2" },
      { id: "3-3", title: "スタック領域とヒープ領域", path: "chapter3/section3" },
      { id: "3-4", title: "アドレスとポインタ", path: "chapter3/section4" },
    ]
  },
  {
    number: "4",
    title: "オペレーティングシステム",
    sections: [
      { id: "4-1", title: "OSとは何か：カーネルとユーザー空間", path: "chapter4/section1" },
      { id: "4-2", title: "プロセスとスレッド", path: "chapter4/section2" },
      { id: "4-3", title: "並行処理と排他制御", path: "chapter4/section3" },
      { id: "4-4", title: "ファイルシステム", path: "chapter4/section4" },
    ]
  },
  {
    number: "5",
    title: "アルゴリズムとデータ構造",
    sections: [
      { id: "5-1", title: "配列と連結リスト", path: "chapter5/section1" },
      { id: "5-2", title: "スタックとキュー：LIFOとFIFO", path: "chapter5/section2" },
      { id: "5-3", title: "計算量と二分探索", path: "chapter5/section3" },
      { id: "5-4", title: "木構造とグラフ", path: "chapter5/section4" },
      { id: "5-5", title: "ソートアルゴリズム", path: "chapter5/section5" },
    ]
  },
  {
    number: "6",
    title: "ネットワーク",
    sections: [
      { id: "6-1", title: "通信プロトコルとレイヤー構造", path: "chapter6/section1" },
      { id: "6-2", title: "IPアドレスとルーティング", path: "chapter6/section2" },
      { id: "6-3", title: "TCPと信頼性のある通信", path: "chapter6/section3" },
      { id: "6-4", title: "名前解決：DNSの仕組み", path: "chapter6/section4" },
      { id: "6-5", title: "HTTPとWebの仕組み", path: "chapter6/section5" },
    ]
  },
  {
    number: "7",
    title: "データベース",
    sections: [
      { id: "7-1", title: "なぜデータベースが必要か", path: "chapter7/section1" },
      { id: "7-2", title: "関係モデルとテーブル設計", path: "chapter7/section2" },
      { id: "7-3", title: "SQLの基本", path: "chapter7/section3" },
      { id: "7-4", title: "トランザクションとACID特性", path: "chapter7/section4" },
    ]
  },
  {
    number: "8",
    title: "セキュリティと計算の限界",
    sections: [
      { id: "8-1", title: "共通鍵暗号と公開鍵暗号", path: "chapter8/section1" },
      { id: "8-2", title: "ハッシュ関数とデジタル署名", path: "chapter8/section2" },
      { id: "8-3", title: "チューリングマシンと計算可能性", path: "chapter8/section3" },
      { id: "8-4", title: "P ≠ NP予想と計算量の壁", path: "chapter8/section4" },
    ]
  },
  {
    number: "9",
    title: "コンパイラとプログラミング言語の設計",
    sections: [
      { id: "9-1", title: "プログラミング言語の分類と翻訳処理", path: "chapter9/section1" },
      { id: "9-2", title: "字句解析", path: "chapter9/section2" },
      { id: "9-3", title: "構文解析と意味解析", path: "chapter9/section3" },
      { id: "9-4", title: "中間表現と最適化", path: "chapter9/section4" },
    ]
  },
  {
    number: "10",
    title: "分散システムとクラウドの設計",
    sections: [
      { id: "10-1", title: "スケールアウトとロードバランシング", path: "chapter10/section1" },
      { id: "10-2", title: "CAP定理とPACELC定理", path: "chapter10/section2" },
      { id: "10-3", title: "一貫性モデルと非同期メッセージング", path: "chapter10/section3" },
      { id: "10-4", title: "分散合意アルゴリズム", path: "chapter10/section4" },
    ]
  },
  {
    number: "11",
    title: "AIと機械学習の計算モデル",
    sections: [
      { id: "11-1", title: "ルールベースから学習へのアプローチ", path: "chapter11/section1" },
      { id: "11-2", title: "人工ニューロンモデルとテンソル演算", path: "chapter11/section2" },
      { id: "11-3", title: "誤差逆伝播法", path: "chapter11/section3" },
      { id: "11-4", title: "深層学習から大規模言語モデル（LLM）へ", path: "chapter11/section4" },
    ]
  }
];

const normalizedCurrentPath = currentPath.replace(/\/$/, "");

// Dynamic SEO config
const siteUrl = Astro.site ? Astro.site.href : "https://hondasan.github.io/cs_study/";
const canonicalUrl = new URL(currentPath ? currentPath : baseUrl, siteUrl).href;
const isHomepage = normalizedCurrentPath === baseUrl.replace(/\/$/, "");
const ogImageUrl = new URL(`${baseUrl}og-image.png`, siteUrl).href;

// Environment variables for analytics and monetization
const gaId = import.meta.env.PUBLIC_GA_ID;
const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const enableAds = import.meta.env.PUBLIC_ENABLE_ADS === 'true';

const jsonLd = isHomepage 
  ? {
      "@context": "https://schema.org",
      "@type": "Book",
      "name": "コンピュータサイエンスの教科書",
      "description": "トランジスタの仕組みから計算量理論までを体系的に学べるコンピュータサイエンスの入門教科書。",
      "url": canonicalUrl,
      "inLanguage": "ja",
      "author": {
        "@type": "Person",
        "name": "honda"
      }
    }
  : {
      "@context": "https://schema.org",
      "@type": "TechArticle",
      "headline": title,
      "description": description,
      "url": canonicalUrl,
      "inLanguage": "ja",
      "isPartOf": {
        "@type": "Book",
        "name": "コンピュータサイエンスの教科書",
        "url": siteUrl
      },
      "author": {
        "@type": "Person",
        "name": "honda"
      }
    };
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="d-Mrl2gdITW1VEJV6sHFfIIAlW9UH7V4TTdWhN3PR7s" />
    <title>{title} | コンピュータサイエンスの教科書</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={isHomepage ? "website" : "article"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${title} | コンピュータサイエンスの教科書`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="コンピュータサイエンスの教科書" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={`${title} | コンピュータサイエンスの教科書`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics (GA4) -->
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${gaId}');
        `} />
      </>
    )}

    <!-- Google AdSense -->
    {adsenseClient && (
      <script 
        async 
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} 
        crossorigin="anonymous"
      ></script>
    )}
    
    <!-- Google Fonts: Lora (Serif) & Outfit (Sans) & Noto Serif JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Noto+Serif+JP:wght@400;600&family=Outfit:wght@400;600&display=swap" rel="stylesheet" />
    
    <style>
      /* Layout specific styles */
      .layout-container {
        display: flex;
        min-height: 100vh;
        width: 100%;
      }
      
      /* Sidebar styling */
      .sidebar {
        width: var(--sidebar-width);
        border-right: 1px solid var(--border-color);
        background-color: var(--bg-color);
        position: fixed;
        top: 0;
        bottom: 0;
        left: 0;
        overflow-y: auto;
        padding: 2rem 1.2rem 3rem;
        font-family: var(--font-sans);
        z-index: 200;
        scrollbar-width: thin;
        scrollbar-color: var(--border-color) transparent;
      }
      
      .sidebar-title {
        font-family: var(--font-serif);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--accent-color);
        margin-bottom: 1.8rem;
        letter-spacing: 0.03em;
        text-align: center;
        border-bottom: 1px solid var(--accent-color);
        padding-bottom: 0.8rem;
        line-height: 1.5;
      }
      
      .sidebar-title a {
        border-bottom: none;
        color: inherit;
      }

      .chapter-group {
        margin-bottom: 1.5rem;
      }
      
      .chapter-header {
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
        font-weight: 600;
        padding-left: 0.5rem;
      }
      
      .section-list {
        list-style: none;
        margin-left: 0;
        margin-bottom: 0;
      }
      
      .section-item {
        margin-bottom: 0.15rem;
        font-size: 0.82rem;
        line-height: 1.4;
      }
      
      .section-item a {
        border-bottom: none;
        color: var(--text-color);
        display: block;
        padding: 0.3rem 0.5rem;
        border-radius: 4px;
        transition: background-color 0.2s, color 0.2s;
      }
      
      .section-item a:hover {
        background-color: var(--accent-light);
        color: var(--accent-color);
        opacity: 1;
      }
      
      .section-item.active a {
        background-color: var(--accent-light);
        color: var(--accent-color);
        font-weight: 600;
      }
      
      /* Main content offset */
      .main-wrapper {
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      
      .content-body {
        flex-grow: 1;
        min-width: 0;
      }

      /* Mobile Header */
      .mobile-header {
        display: none;
        height: 56px;
        border-bottom: 1px solid var(--border-color);
        background-color: var(--bg-color);
        align-items: center;
        justify-content: space-between;
        padding: 0 1.2rem;
        position: sticky;
        top: 0;
        z-index: 150;
      }

      .mobile-title {
        font-family: var(--font-serif);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--accent-color);
      }

      .menu-toggle {
        background: none;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        font-size: 1.2rem;
        cursor: pointer;
        color: var(--accent-color);
        padding: 0.3rem 0.6rem;
        transition: background-color 0.2s;
      }
      
      .menu-toggle:hover {
        background-color: var(--accent-light);
      }

      /* Sidebar Overlay (mobile) */
      .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.3);
        z-index: 190;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      
      .sidebar-overlay.visible {
        opacity: 1;
      }

      /* Simple Footer inside main wrapper */
      .book-footer {
        border-top: 1px solid var(--border-color);
        padding: 2rem 1.5rem;
        font-family: var(--font-sans);
        font-size: 0.78rem;
        color: var(--text-muted);
        text-align: center;
        background-color: var(--bg-color);
      }

      /* Responsive styling */
      @media (max-width: 900px) {
        .layout-container {
          flex-direction: column;
        }

        .sidebar {
          transform: translateX(-100%);
          transition: transform 0.3s ease;
          width: 280px;
          box-shadow: none;
        }

        .sidebar.open {
          transform: translateX(0);
          box-shadow: 2px 0 12px rgba(0, 0, 0, 0.08);
        }
        
        .sidebar-overlay {
          display: block;
          pointer-events: none;
        }
        
        .sidebar-overlay.visible {
          pointer-events: auto;
        }

        .main-wrapper {
          margin-left: 0;
          width: 100%;
          min-width: 0;
        }

        .mobile-header {
          display: flex;
        }
      }
      
      @media print {
        .sidebar, .mobile-header, .book-footer, .sidebar-overlay {
          display: none !important;
        }
        .main-wrapper {
          margin-left: 0;
          width: 100%;
        }
      }

      /* Ad Styles */
      .ad-label {
        font-size: 0.65rem;
        color: var(--text-muted);
        text-align: center;
        margin-bottom: 0.3rem;
        font-family: var(--font-sans);
        letter-spacing: 0.05em;
      }
      
      .ad-box {
        background-color: var(--quote-bg);
        border: 1px dashed var(--border-color);
        border-radius: 4px;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100px;
        padding: 0.5rem;
      }
      
      .ad-placeholder {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        color: var(--text-muted);
        text-align: center;
        line-height: 1.4;
      }

      .sidebar-ad {
        margin-top: 2rem;
        padding: 0 0.2rem;
      }

      .content-ad {
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
      }
    </style>
    <script is:inline>
      // Load adsense script again for dynamcially injected tags if needed
    </script>
  </head>
  <body>
    <div class="layout-container">
      <!-- Mobile Header -->
      <header class="mobile-header no-print">
        <div class="mobile-title">コンピュータサイエンスの教科書</div>
        <button class="menu-toggle" id="menuToggle" aria-label="メニューを開く">☰</button>
      </header>

      <!-- Sidebar Overlay (mobile) -->
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <!-- Sidebar Table of Contents -->
      <aside class="sidebar no-print no-underline" id="sidebar">
        <div class="sidebar-title">
          <a href={baseUrl}>コンピュータサイエンス<br/>の教科書</a>
        </div>
        <nav>
          {chapters.map((ch) => (
            <div class="chapter-group">
              <div class="chapter-header">第{ch.number}章 {ch.title}</div>
              <ul class="section-list">
                {ch.sections.map((sec) => {
                  const fullPath = `${baseUrl}${sec.path}`.replace(/\/$/, "");
                  const isActive = normalizedCurrentPath === fullPath;
                  return (
                    <li class={`section-item ${isActive ? 'active' : ''}`}>
                      <a href={`${baseUrl}${sec.path}`}>
                        {sec.id}. {sec.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
          <div class="chapter-group">
            <div class="chapter-header">付録</div>
            <ul class="section-list">
              <li class={`section-item ${normalizedCurrentPath === baseUrl + 'glossary' ? 'active' : ''}`}>
                <a href={`${baseUrl}glossary`}>用語集（Glossary）</a>
              </li>
            </ul>
          </div>
        </nav>
        {enableAds && (
          <div class="sidebar-ad no-print">
            <div class="ad-label">スポンサーリンク</div>
            <div class="ad-box">
              {adsenseClient ? (
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client={adsenseClient}
                     data-ad-slot="xxxxxxxxxx"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
              ) : (
                <div class="ad-placeholder">広告掲載スペース</div>
              )}
            </div>
          </div>
        )}
      </aside>

      <!-- Main Content Area -->
      <div class="main-wrapper">
        <main class="content-body">
          <article class="main-content">
            <slot />
            {enableAds && (
              <div class="content-ad no-print">
                <div class="ad-label">スポンサーリンク</div>
                <div class="ad-box">
                  {adsenseClient ? (
                    <ins class="adsbygoogle"
                         style="display:block"
                         data-ad-client={adsenseClient}
                         data-ad-slot="yyyyyyyyyy"
                         data-ad-format="auto"
                         data-full-width-responsive="true"></ins>
                  ) : (
                    <div class="ad-placeholder">広告掲載スペース</div>
                  )}
                </div>
              </div>
            )}
          </article>
        </main>

        <!-- Simple Footer -->
        <footer class="book-footer">
          <p>© {new Date().getFullYear()} コンピュータサイエンスの教科書</p>
        </footer>
      </div>
    </div>

    <!-- Mobile Navigation Script -->
    <script>
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebarOverlay');

      function openSidebar() {
        sidebar?.classList.add('open');
        overlay?.classList.add('visible');
        if (menuToggle) menuToggle.textContent = '✕';
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('visible');
        if (menuToggle) menuToggle.textContent = '☰';
        document.body.style.overflow = '';
      }

      menuToggle?.addEventListener('click', () => {
        if (sidebar?.classList.contains('open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });
      
      overlay?.addEventListener('click', closeSidebar);

      // Close sidebar when clicking links inside on mobile
      sidebar?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 900) {
            closeSidebar();
          }
        });
      });

      // アクティブなセクション（現在の章）にサイドバーのスクロール位置を追従させる
      const activeSection = sidebar?.querySelector('.section-item.active');
      if (activeSection) {
        activeSection.scrollIntoView({ block: 'center', inline: 'nearest' });
      }

      // --- Table Responsive Enhancements ---
      function initializeResponsiveTables() {
        const tables = document.querySelectorAll('table');
        tables.forEach(table => {
          // ネストされたテーブル（真理値表内のテーブルなど）は処理をスキップ
          if (table.closest('td')) return;

          const headers = Array.from(table.querySelectorAll('thead th'));
          const rows = Array.from(table.querySelectorAll('tbody tr'));
          const colCount = headers.length;

          // 4列以上は自動的にカードレイアウト
          let shouldCard = colCount >= 4;

          if (!shouldCard && colCount >= 2) {
            let totalLength = 0;
            let maxLength = 0;
            const tds = table.querySelectorAll('tbody td');
            tds.forEach(td => {
              const textLength = td.textContent.trim().length;
              totalLength += textLength;
              if (textLength > maxLength) {
                maxLength = textLength;
              }
            });
            const avgLength = tds.length ? (totalLength / tds.length) : 0;
            
            // 1セル平均12文字を超えるか、または1つでも30文字を超える長いテキストがある場合はカード化
            if (avgLength > 12 || maxLength > 30) {
              shouldCard = true;
            }
          }

          if (shouldCard && headers.length > 0) {
            table.classList.add('responsive-card-table');
            const headerTexts = headers.map(th => th.textContent.trim());
            rows.forEach(tr => {
              const tds = Array.from(tr.querySelectorAll(':scope > td'));
              tds.forEach((td, index) => {
                if (headerTexts[index]) {
                  td.setAttribute('data-label', headerTexts[index]);
                }
              });
            });
          } else {
            table.classList.add('responsive-simple-table');
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeResponsiveTables);
      } else {
        initializeResponsiveTables();
      }
    </script>
