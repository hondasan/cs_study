---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { 
  title, 
  description = "コンピュータサイエンスを体系的に、直感的かつ美しく学ぶ教科書",
  currentPath = "" 
} = Astro.props;

// base url (for GitHub Pages deployment)
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;

// Curriculum navigation structure
const chapters = [
  {
    number: "1",
    title: "情報の表現",
    sections: [
      { id: "1-1", title: "電球1個から始める通信", path: "chapter1/section1" },
      { id: "1-2", title: "数の表現：2進数と16進数", path: "chapter1/section2" },
      { id: "1-3", title: "文字の表現：ASCIIからUnicodeへ", path: "chapter1/section3" },
      { id: "1-4", title: "メモリの中を覗く：バイトとエンディアン", path: "chapter1/section4" },
    ]
  },
  {
    number: "2",
    title: "論理回路からCPUへ",
    sections: [
      { id: "2-1", title: "スイッチとしてのトランジスタ", path: "chapter2/section1" },
      { id: "2-2", title: "基本論理回路と真理値表", path: "chapter2/section2" },
      { id: "2-3", title: "計算の実現：加算器", path: "chapter2/section3" },
      { id: "2-4", title: "クロックと同期：記憶の回路", path: "chapter2/section4" },
      { id: "2-5", title: "CPUの設計図", path: "chapter2/section5" },
    ]
  },
  {
    number: "3",
    title: "プログラムとメモリ",
    sections: [
      { id: "3-1", title: "ソースコードから機械語へ", path: "chapter3/section1" },
      { id: "3-2", title: "メモリ階層：レジスタからストレージまで", path: "chapter3/section2" },
      { id: "3-3", title: "スタック領域とヒープ領域", path: "chapter3/section3" },
      { id: "3-4", title: "アドレスとポインタ", path: "chapter3/section4" },
    ]
  },
  {
    number: "4",
    title: "オペレーティングシステム",
    sections: [
      { id: "4-1", title: "OSとは何か：カーネルとユーザー空間", path: "chapter4/section1" },
      { id: "4-2", title: "プロセスとスレッド", path: "chapter4/section2" },
      { id: "4-3", title: "並行処理と排他制御", path: "chapter4/section3" },
      { id: "4-4", title: "ファイルシステム", path: "chapter4/section4" },
    ]
  },
  {
    number: "5",
    title: "アルゴリズムとデータ構造",
    sections: [
      { id: "5-1", title: "配列と連結リスト", path: "chapter5/section1" },
      { id: "5-2", title: "スタックとキュー：LIFOとFIFO", path: "chapter5/section2" },
      { id: "5-3", title: "計算量と二分探索", path: "chapter5/section3" },
      { id: "5-4", title: "木構造とグラフ", path: "chapter5/section4" },
      { id: "5-5", title: "ソートアルゴリズム", path: "chapter5/section5" },
    ]
  },
  {
    number: "6",
    title: "ネットワーク",
    sections: [
      { id: "6-1", title: "通信プロトコルとレイヤー構造", path: "chapter6/section1" },
      { id: "6-2", title: "IPアドレスとルーティング", path: "chapter6/section2" },
      { id: "6-3", title: "TCPと信頼性のある通信", path: "chapter6/section3" },
      { id: "6-4", title: "名前解決：DNSの仕組み", path: "chapter6/section4" },
      { id: "6-5", title: "HTTPとWebの仕組み", path: "chapter6/section5" },
    ]
  },
  {
    number: "7",
    title: "データベース",
    sections: [
      { id: "7-1", title: "なぜデータベースが必要か", path: "chapter7/section1" },
      { id: "7-2", title: "関係モデルとテーブル設計", path: "chapter7/section2" },
      { id: "7-3", title: "SQLの基本", path: "chapter7/section3" },
      { id: "7-4", title: "トランザクションとACID特性", path: "chapter7/section4" },
    ]
  },
  {
    number: "8",
    title: "セキュリティと計算の限界",
    sections: [
      { id: "8-1", title: "共通鍵暗号と公開鍵暗号", path: "chapter8/section1" },
      { id: "8-2", title: "ハッシュ関数とデジタル署名", path: "chapter8/section2" },
      { id: "8-3", title: "チューリングマシンと計算可能性", path: "chapter8/section3" },
      { id: "8-4", title: "P ≠ NP予想と計算量の壁", path: "chapter8/section4" },
    ]
  }
];

const normalizedCurrentPath = currentPath.replace(/\/$/, "");
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | コンピュータサイエンスの教科書</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts: Lora (Serif) & Outfit (Sans) & Noto Serif JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Noto+Serif+JP:wght@400;600&family=Outfit:wght@400;600&display=swap" rel="stylesheet" />
    
    <style>
      /* Layout specific styles */
      .layout-container {
        display: flex;
        min-height: 100vh;
        width: 100%;
      }
      
      /* Sidebar styling */
      .sidebar {
        width: var(--sidebar-width);
        border-right: 1px solid var(--border-color);
        background-color: var(--bg-color);
        position: fixed;
        top: 0;
        bottom: 0;
        left: 0;
        overflow-y: auto;
        padding: 2rem 1.2rem 3rem;
        font-family: var(--font-sans);
        z-index: 200;
        scrollbar-width: thin;
        scrollbar-color: var(--border-color) transparent;
      }
      
      .sidebar-title {
        font-family: var(--font-serif);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--accent-color);
        margin-bottom: 1.8rem;
        letter-spacing: 0.03em;
        text-align: center;
        border-bottom: 1px solid var(--accent-color);
        padding-bottom: 0.8rem;
        line-height: 1.5;
      }
      
      .sidebar-title a {
        border-bottom: none;
        color: inherit;
      }

      .chapter-group {
        margin-bottom: 1.5rem;
      }
      
      .chapter-header {
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
        font-weight: 600;
        padding-left: 0.5rem;
      }
      
      .section-list {
        list-style: none;
        margin-left: 0;
        margin-bottom: 0;
      }
      
      .section-item {
        margin-bottom: 0.15rem;
        font-size: 0.82rem;
        line-height: 1.4;
      }
      
      .section-item a {
        border-bottom: none;
        color: var(--text-color);
        display: block;
        padding: 0.3rem 0.5rem;
        border-radius: 4px;
        transition: background-color 0.2s, color 0.2s;
      }
      
      .section-item a:hover {
        background-color: var(--accent-light);
        color: var(--accent-color);
        opacity: 1;
      }
      
      .section-item.active a {
        background-color: var(--accent-light);
        color: var(--accent-color);
        font-weight: 600;
      }
      
      /* Main content offset */
      .main-wrapper {
        margin-left: var(--sidebar-width);
        width: calc(100% - var(--sidebar-width));
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      
      .content-body {
        flex-grow: 1;
      }

      /* Mobile Header */
      .mobile-header {
        display: none;
        height: 56px;
        border-bottom: 1px solid var(--border-color);
        background-color: var(--bg-color);
        align-items: center;
        justify-content: space-between;
        padding: 0 1.2rem;
        position: sticky;
        top: 0;
        z-index: 150;
      }

      .mobile-title {
        font-family: var(--font-serif);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--accent-color);
      }

      .menu-toggle {
        background: none;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        font-size: 1.2rem;
        cursor: pointer;
        color: var(--accent-color);
        padding: 0.3rem 0.6rem;
        transition: background-color 0.2s;
      }
      
      .menu-toggle:hover {
        background-color: var(--accent-light);
      }

      /* Sidebar Overlay (mobile) */
      .sidebar-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.3);
        z-index: 190;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      
      .sidebar-overlay.visible {
        opacity: 1;
      }

      /* Simple Footer inside main wrapper */
      .book-footer {
        border-top: 1px solid var(--border-color);
        padding: 2rem 1.5rem;
        font-family: var(--font-sans);
        font-size: 0.78rem;
        color: var(--text-muted);
        text-align: center;
        background-color: var(--bg-color);
      }

      /* Responsive styling */
      @media (max-width: 900px) {
        .sidebar {
          transform: translateX(-100%);
          transition: transform 0.3s ease;
          width: 280px;
          box-shadow: none;
        }

        .sidebar.open {
          transform: translateX(0);
          box-shadow: 2px 0 12px rgba(0, 0, 0, 0.08);
        }
        
        .sidebar-overlay {
          display: block;
          pointer-events: none;
        }
        
        .sidebar-overlay.visible {
          pointer-events: auto;
        }

        .main-wrapper {
          margin-left: 0;
          width: 100%;
        }

        .mobile-header {
          display: flex;
        }
      }
      
      @media print {
        .sidebar, .mobile-header, .book-footer, .sidebar-overlay {
          display: none !important;
        }
        .main-wrapper {
          margin-left: 0;
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="layout-container">
      <!-- Mobile Header -->
      <header class="mobile-header no-print">
        <div class="mobile-title">コンピュータサイエンスの教科書</div>
        <button class="menu-toggle" id="menuToggle" aria-label="メニューを開く">☰</button>
      </header>

      <!-- Sidebar Overlay (mobile) -->
      <div class="sidebar-overlay" id="sidebarOverlay"></div>

      <!-- Sidebar Table of Contents -->
      <aside class="sidebar no-print no-underline" id="sidebar">
        <div class="sidebar-title">
          <a href={baseUrl}>コンピュータサイエンス<br/>の教科書</a>
        </div>
        <nav>
          {chapters.map((ch) => (
            <div class="chapter-group">
              <div class="chapter-header">第{ch.number}章 {ch.title}</div>
              <ul class="section-list">
                {ch.sections.map((sec) => {
                  const fullPath = `${baseUrl}${sec.path}`.replace(/\/$/, "");
                  const isActive = normalizedCurrentPath === fullPath;
                  return (
                    <li class={`section-item ${isActive ? 'active' : ''}`}>
                      <a href={`${baseUrl}${sec.path}`}>
                        {sec.id}. {sec.title}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Main Content Area -->
      <div class="main-wrapper">
        <main class="content-body">
          <article class="main-content">
            <slot />
          </article>
        </main>

        <!-- Simple Footer -->
        <footer class="book-footer">
          <p>© {new Date().getFullYear()} コンピュータサイエンスの教科書</p>
        </footer>
      </div>
    </div>

    <!-- Mobile Navigation Script -->
    <script>
      const menuToggle = document.getElementById('menuToggle');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebarOverlay');

      function openSidebar() {
        sidebar?.classList.add('open');
        overlay?.classList.add('visible');
        if (menuToggle) menuToggle.textContent = '✕';
        document.body.style.overflow = 'hidden';
      }

      function closeSidebar() {
        sidebar?.classList.remove('open');
        overlay?.classList.remove('visible');
        if (menuToggle) menuToggle.textContent = '☰';
        document.body.style.overflow = '';
      }

      menuToggle?.addEventListener('click', () => {
        if (sidebar?.classList.contains('open')) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });
      
      overlay?.addEventListener('click', closeSidebar);

      // Close sidebar when clicking links inside on mobile
      sidebar?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth <= 900) {
            closeSidebar();
          }
        });
      });
    </script>
  </body>
</html>
