    <div class="pagination-next">
      <a href={`${baseUrl}chapter9/section2`}>
        <span class="label">9-2. 字句解析 (Lexical Analysis)</span>
        <span class="arrow">→</span>
      </a>
    </div>
  </div>
</BookLayout>
