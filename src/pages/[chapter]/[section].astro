---
import BookLayout from '../../layouts/BookLayout.astro';

export function getStaticPaths() {
  return [
    // 第3章 プログラムとメモリ
    { params: { chapter: 'chapter3', section: 'section1' }, props: { title: '3-1. ソースコードから機械語へ', prev: 'chapter2/section5', next: 'chapter3/section2' } },
    { params: { chapter: 'chapter3', section: 'section2' }, props: { title: '3-2. メモリ階層：レジスタからストレージまで', prev: 'chapter3/section1', next: 'chapter3/section3' } },
    { params: { chapter: 'chapter3', section: 'section3' }, props: { title: '3-3. スタック領域とヒープ領域', prev: 'chapter3/section2', next: 'chapter3/section4' } },
    { params: { chapter: 'chapter3', section: 'section4' }, props: { title: '3-4. アドレスとポインタ', prev: 'chapter3/section3', next: 'chapter4/section1' } },
    
    // 第4章 オペレーティングシステム（★新設）
    { params: { chapter: 'chapter4', section: 'section1' }, props: { title: '4-1. OSとは何か：カーネルとユーザー空間', prev: 'chapter3/section4', next: 'chapter4/section2' } },
    { params: { chapter: 'chapter4', section: 'section2' }, props: { title: '4-2. プロセスとスレッド', prev: 'chapter4/section1', next: 'chapter4/section3' } },
    { params: { chapter: 'chapter4', section: 'section3' }, props: { title: '4-3. 並行処理と排他制御', prev: 'chapter4/section2', next: 'chapter4/section4' } },
    { params: { chapter: 'chapter4', section: 'section4' }, props: { title: '4-4. ファイルシステム', prev: 'chapter4/section3', next: 'chapter5/section1' } },
    
    // 第5章 アルゴリズムとデータ構造
    { params: { chapter: 'chapter5', section: 'section1' }, props: { title: '5-1. 配列と連結リスト', prev: 'chapter4/section4', next: 'chapter5/section2' } },
    { params: { chapter: 'chapter5', section: 'section2' }, props: { title: '5-2. スタックとキュー：LIFOとFIFO', prev: 'chapter5/section1', next: 'chapter5/section3' } },
    { params: { chapter: 'chapter5', section: 'section3' }, props: { title: '5-3. 計算量と二分探索', prev: 'chapter5/section2', next: 'chapter5/section4' } },
    { params: { chapter: 'chapter5', section: 'section4' }, props: { title: '5-4. 木構造とグラフ', prev: 'chapter5/section3', next: 'chapter5/section5' } },
    { params: { chapter: 'chapter5', section: 'section5' }, props: { title: '5-5. ソートアルゴリズム', prev: 'chapter5/section4', next: 'chapter6/section1' } },
    
    // 第6章 ネットワーク
    { params: { chapter: 'chapter6', section: 'section1' }, props: { title: '6-1. 通信プロトコルとレイヤー構造', prev: 'chapter5/section5', next: 'chapter6/section2' } },
    { params: { chapter: 'chapter6', section: 'section2' }, props: { title: '6-2. IPアドレスとルーティング', prev: 'chapter6/section1', next: 'chapter6/section3' } },
    { params: { chapter: 'chapter6', section: 'section3' }, props: { title: '6-3. TCPと信頼性のある通信', prev: 'chapter6/section2', next: 'chapter6/section4' } },
    { params: { chapter: 'chapter6', section: 'section4' }, props: { title: '6-4. 名前解決：DNSの仕組み', prev: 'chapter6/section3', next: 'chapter6/section5' } },
    { params: { chapter: 'chapter6', section: 'section5' }, props: { title: '6-5. HTTPとWebの仕組み', prev: 'chapter6/section4', next: 'chapter7/section1' } },
    
    // 第7章 データベース
    { params: { chapter: 'chapter7', section: 'section1' }, props: { title: '7-1. なぜデータベースが必要か', prev: 'chapter6/section5', next: 'chapter7/section2' } },
    { params: { chapter: 'chapter7', section: 'section2' }, props: { title: '7-2. 関係モデルとテーブル設計', prev: 'chapter7/section1', next: 'chapter7/section3' } },
    { params: { chapter: 'chapter7', section: 'section3' }, props: { title: '7-3. SQLの基本', prev: 'chapter7/section2', next: 'chapter7/section4' } },
    { params: { chapter: 'chapter7', section: 'section4' }, props: { title: '7-4. トランザクションとACID特性', prev: 'chapter7/section3', next: 'chapter8/section1' } },
    
    // 第8章 セキュリティと計算の限界
    { params: { chapter: 'chapter8', section: 'section1' }, props: { title: '8-1. 共通鍵暗号と公開鍵暗号', prev: 'chapter7/section4', next: 'chapter8/section2' } },
    { params: { chapter: 'chapter8', section: 'section2' }, props: { title: '8-2. ハッシュ関数とデジタル署名', prev: 'chapter8/section1', next: 'chapter8/section3' } },
    { params: { chapter: 'chapter8', section: 'section3' }, props: { title: '8-3. チューリングマシンと計算可能性', prev: 'chapter8/section2', next: 'chapter8/section4' } },
    { params: { chapter: 'chapter8', section: 'section4' }, props: { title: '8-4. P ≠ NP予想と計算量の壁', prev: 'chapter8/section3', next: null } },
  ];
}

const { chapter, section } = Astro.params;
const { title, prev, next } = Astro.props;

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;

const chapterNameMap: Record<string, string> = {
  chapter1: '第1章 情報の表現',
  chapter2: '第2章 論理回路からCPUへ',
  chapter3: '第3章 プログラムとメモリ',
  chapter4: '第4章 オペレーティングシステム',
  chapter5: '第5章 アルゴリズムとデータ構造',
  chapter6: '第6章 ネットワーク',
  chapter7: '第7章 データベース',
  chapter8: '第8章 セキュリティと計算の限界',
};
const chapterLabel = chapterNameMap[chapter] || '';
---

<BookLayout title={title} currentPath={`${baseUrl}${chapter}/${section}`}>
  <div class="section-nav-breadcrumbs">
    <a href={baseUrl}>ホーム</a> ＞ <span class="muted">{chapterLabel}</span>
  </div>

  <header class="section-header">
    <h1 class="section-title">{title}</h1>
  </header>

  <div class="section-body">
    <div class="note-box">
      <div class="note-box-title">お知らせ</div>
      <p>このセクションは現在準備中です。後ほどコンテンツが追加されます。</p>
    </div>
  </div>

  <!-- Textbook navigation (Footer pagination) -->
  <div class="textbook-pagination">
    <div class="pagination-prev">
      {prev ? (
        <a href={`${baseUrl}${prev}`}>
          <span class="arrow">←</span>
          <span class="label">前のセクションへ</span>
        </a>
      ) : (
        <a href={baseUrl}>
          <span class="arrow">←</span>
          <span class="label">ホームへ戻る</span>
        </a>
      )}
    </div>
    <div class="pagination-next">
      {next ? (
        <a href={`${baseUrl}${next}`}>
          <span class="label">次のセクションへ</span>
          <span class="arrow">→</span>
        </a>
      ) : (
        <span class="muted">終章</span>
      )}
    </div>
  </div>

</BookLayout>
