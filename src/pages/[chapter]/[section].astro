---
import BookLayout from '../../layouts/BookLayout.astro';

export function getStaticPaths() {
  return [
    // 第8章 セキュリティと計算の限界
    { params: { chapter: 'chapter8', section: 'section1' }, props: { title: '8-1. 共通鍵暗号と公開鍵暗号', prev: 'chapter7/section4', next: 'chapter8/section2' } },
    { params: { chapter: 'chapter8', section: 'section2' }, props: { title: '8-2. ハッシュ関数とデジタル署名', prev: 'chapter8/section1', next: 'chapter8/section3' } },
    { params: { chapter: 'chapter8', section: 'section3' }, props: { title: '8-3. チューリングマシンと計算可能性', prev: 'chapter8/section2', next: 'chapter8/section4' } },
    { params: { chapter: 'chapter8', section: 'section4' }, props: { title: '8-4. P ≠ NP予想と計算量の壁', prev: 'chapter8/section3', next: null } },
  ];
}

const { chapter, section } = Astro.params;
const { title, prev, next } = Astro.props;

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;

const chapterNameMap: Record<string, string> = {
  chapter1: '第1章 情報の表現',
  chapter2: '第2章 論理回路からCPUへ',
  chapter3: '第3章 プログラムとメモリ',
  chapter4: '第4章 オペレーティングシステム',
  chapter5: '第5章 アルゴリズムとデータ構造',
  chapter6: '第6章 ネットワーク',
  chapter7: '第7章 データベース',
  chapter8: '第8章 セキュリティと計算の限界',
};
const chapterLabel = chapterNameMap[chapter] || '';
---

<BookLayout title={title} currentPath={`${baseUrl}${chapter}/${section}`}>
  <div class="section-nav-breadcrumbs">
    <a href={baseUrl}>ホーム</a> ＞ <span class="muted">{chapterLabel}</span>
  </div>

  <header class="section-header">
    <h1 class="section-title">{title}</h1>
  </header>

  <div class="section-body">
    <div class="note-box">
      <div class="note-box-title">お知らせ</div>
      <p>このセクションは現在準備中です。後ほどコンテンツが追加されます。</p>
    </div>
  </div>

  <!-- Textbook navigation (Footer pagination) -->
  <div class="textbook-pagination">
    <div class="pagination-prev">
      {prev ? (
        <a href={`${baseUrl}${prev}`}>
          <span class="arrow">←</span>
          <span class="label">前のセクションへ</span>
        </a>
      ) : (
        <a href={baseUrl}>
          <span class="arrow">←</span>
          <span class="label">ホームへ戻る</span>
        </a>
      )}
    </div>
    <div class="pagination-next">
      {next ? (
        <a href={`${baseUrl}${next}`}>
          <span class="label">次のセクションへ</span>
          <span class="arrow">→</span>
        </a>
      ) : (
        <span class="muted">終章</span>
      )}
    </div>
  </div>

</BookLayout>
