---
import BookLayout from '../layouts/BookLayout.astro';

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;

const chapters = [
  { number: "1", title: "情報の表現", description: "電球1個の通信から、2進数・文字コード・メモリの仕組みまで" },
  { number: "2", title: "論理回路からCPUへ", description: "トランジスタ、論理ゲート、加算器、そしてCPUの設計" },
  { number: "3", title: "プログラムとメモリ", description: "ソースコードの翻訳、メモリ階層、スタックとヒープ" },
  { number: "4", title: "オペレーティングシステム", description: "カーネル、プロセス管理、並行処理、ファイルシステム" },
  { number: "5", title: "アルゴリズムとデータ構造", description: "配列・木・グラフ、計算量、探索とソート" },
  { number: "6", title: "ネットワーク", description: "TCP/IP、ルーティング、DNS、HTTPの設計思想" },
  { number: "7", title: "データベース", description: "関係モデル、SQL、トランザクションの信頼性" },
  { number: "8", title: "セキュリティと計算の限界", description: "暗号技術、ハッシュ関数、計算可能性の境界線" },
  { number: "9", title: "コンパイラとプログラミング言語の設計", description: "字句解析・構文解析から中間表現、最適化のメカニズム" },
  { number: "10", title: "分散システムとクラウドの設計", description: "ロードバランシング、CAP定理、レプリケーションと分散合意" },
  { number: "11", title: "AIと機械学習の計算モデル", description: "勾配降下法、テンソル演算、誤差逆伝播からLLMまで" },
];
---

<BookLayout title="ホーム" currentPath={baseUrl}>
  <div class="book-cover">
    <div class="book-tagline">FROM PHYSICAL SWITCHES TO THEORETICAL LIMITS</div>
    <h1 class="book-main-title">コンピュータサイエンス<br/>の教科書</h1>
    <div class="book-subtitle">物理世界から計算限界までを紡ぐ、不変の基礎知識</div>
    
    <div class="divider"></div>
    
    <div class="preface">
      <h2>序文</h2>
      <p>
        コンピュータは日常に溶け込み、空気のような存在になりました。しかし、その中身がどう動いているのかは意外と知られていません。
      </p>
      <p>
        コンピュータサイエンスとは、流行のプログラミング言語やツールの使い方ではありません。電気の「オン・オフ」から、宇宙の寿命をかけても解けない問題の存在証明まで――人類が積み上げてきた不変の知の体系です。
      </p>
      <p>
        本書では、11の章を通して、コンピュータの世界を一歩ずつ歩いていきます。
      </p>
    </div>

    <div class="toc-section">
      <h2>目次</h2>
      <ol class="toc-list">
        {chapters.map((ch) => (
          <li class="toc-item">
            <a href={`${baseUrl}chapter${ch.number}/section1`}>
              <span class="toc-chapter-title">第{ch.number}章　{ch.title}</span>
              <span class="toc-chapter-desc">{ch.description}</span>
            </a>
          </li>
        ))}
      </ol>
    </div>

    <div class="start-btn-container">
      <a href={`${baseUrl}chapter1/section1`} class="start-btn">第1章から読み始める →</a>
    </div>
  </div>

  <style>
    .book-cover {
      max-width: 620px;
      margin: 0 auto;
      padding-top: 1.5rem;
    }
    
    .book-tagline {
      font-family: var(--font-sans);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      text-align: center;
      margin-bottom: 1rem;
    }
    
    .book-main-title {
      font-size: 2.4rem;
      font-weight: 600;
      text-align: center;
      line-height: 1.3;
      color: var(--accent-color);
      border-bottom: none;
      margin-bottom: 1rem;
    }
    
    .book-subtitle {
      font-family: var(--font-serif);
      font-size: 1rem;
      text-align: center;
      color: var(--text-muted);
      margin-bottom: 2.5rem;
      font-style: italic;
    }
    
    .divider {
      height: 1px;
      background-color: var(--border-color);
      width: 80px;
      margin: 0 auto 2.5rem auto;
    }
    
    .preface {
      font-size: 0.95rem;
      line-height: 1.9;
    }
    
    .preface h2 {
      font-family: var(--font-serif);
      text-align: center;
      margin-bottom: 1.2rem;
      font-size: 1.3rem;
      border-bottom: none;
    }

    /* Table of Contents */
    .toc-section {
      margin-top: 3rem;
    }

    .toc-section h2 {
      font-family: var(--font-serif);
      text-align: center;
      margin-bottom: 1.5rem;
      font-size: 1.3rem;
      border-bottom: none;
    }

    .toc-list {
      list-style: none;
      margin-left: 0;
      margin-bottom: 0;
    }

    .toc-item {
      margin-bottom: 0;
      border-bottom: 1px solid var(--border-color);
    }

    .toc-item:first-child {
      border-top: 1px solid var(--border-color);
    }

    .toc-item a {
      display: block;
      padding: 0.9rem 0.6rem;
      border-bottom: none;
      color: var(--text-color);
      transition: background-color 0.2s, color 0.2s;
    }

    .toc-item a:hover {
      background-color: var(--accent-light);
      color: var(--accent-color);
    }

    .toc-chapter-title {
      display: block;
      font-family: var(--font-serif);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .toc-chapter-desc {
      display: block;
      font-family: var(--font-sans);
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 0.2rem;
    }

    .toc-item a:hover .toc-chapter-desc {
      color: var(--accent-color);
      opacity: 0.7;
    }
    
    .start-btn-container {
      text-align: center;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
    }
    
    .start-btn {
      font-family: var(--font-sans);
      display: inline-block;
      padding: 0.75rem 2rem;
      background-color: var(--accent-color);
      color: #ffffff;
      border-radius: 4px;
      border-bottom: none;
      font-size: 0.9rem;
      letter-spacing: 0.03em;
      font-weight: 600;
      transition: background-color 0.2s;
    }
    
    .start-btn:hover {
      background-color: #152d4a;
      color: #ffffff;
    }

    @media (max-width: 600px) {
      .book-main-title {
        font-size: 1.8rem;
      }

      .book-tagline {
        font-size: 0.55rem;
      }

      .book-subtitle {
        font-size: 0.9rem;
      }

      .toc-chapter-title {
        font-size: 0.9rem;
      }
    }
  </style>
</BookLayout>
